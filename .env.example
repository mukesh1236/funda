# Finnhub API key — free tier at https://finnhub.io/register
FINNHUB_API_KEY=

# SQLite database location
RECOMMENDATIONS_DB_PATH=./data/recommendations.db

# Comma-separated tickers to track daily (e.g. AAPL,MSFT,NVDA).
# Leave empty to use the built-in default watchlist.
TRACKED_UNIVERSE=

# Best-effort Morningstar scrape for star-rating / fair-value enrichment
MORNINGSTAR_SCRAPE_ENABLED=true

# Yahoo Finance analyst data via yfinance — free, no key
YAHOO_ENABLED=true

# TipRanks consensus (best-effort scrape; no official free API)
TIPRANKS_ENABLED=true

# Financial Modeling Prep — optional named-firm analyst grades (free key)
FMP_API_KEY=

# Days a recommendation's target is given to be hit before it's marked missed
OUTCOME_HORIZON_DAYS=365

# LLM for chat + narratives: rule | openrouter | gemini | grok | ollama | auto
# "auto" tries OpenRouter (free open-source models) first, then Grok, Gemini,
# Ollama. RECOMMENDED for affordability: openrouter with a ":free" model.
SUMMARY_PROVIDER=rule

# OpenRouter — one key, many models; ":free" models cost nothing.
# Key at https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_MODEL=deepseek/deepseek-chat-v3.1:free

# Tavily — live web search, grounds "why is X falling" style questions with
# real recent context. Free tier (1,000 searches/month): https://tavily.com
TAVILY_API_KEY=

# Google Gemini (free tier) — https://aistudio.google.com/apikey
GEMINI_API_KEY=

# xAI Grok — https://console.x.ai
GROK_API_KEY=

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# SEC EDGAR etiquette header for N-PORT fund-holdings fetches (identify your app)
EDGAR_USER_AGENT=

# OpenFIGI (optional, free key) — raises CUSIP->ticker resolution rate limits
# for full fund holdings. https://www.openfigi.com/api
OPENFIGI_API_KEY=

# ── SRE / AI observability ────────────────────────────────────────────────────
# Daily AI budgets (0 disables). Defaults match OpenRouter's free tier.
AI_DAILY_CALL_BUDGET=50
AI_DAILY_TOKEN_BUDGET=0
# Slack-compatible webhook for threshold alerts; empty = log-only
ALERT_WEBHOOK_URL=
ALERT_COOLDOWN_HOURS=6
FRESHNESS_GRACE_HOURS=2

# Notifier: "console" (default) or "whatsapp"
NOTIFIER=console

# WhatsApp assistant (Phase 1 — Twilio sandbox). From the Twilio console:
# https://console.twilio.com/ ; sandbox docs: twilio.com/docs/whatsapp/sandbox
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# The sandbox opt-in phrase shown to users (e.g. "join olive-tiger")
WHATSAPP_SANDBOX_JOIN=

# Daily job schedule (24h local time)
DAILY_JOB_HOUR=8
DAILY_JOB_MINUTE=0
# Run the in-process scheduler when the API starts
ENABLE_SCHEDULER=true

# FastAPI
API_HOST=0.0.0.0
API_PORT=8100

# Auth — secret key used to sign session cookies. Set a long random string in
# production (e.g. `python -c "import secrets; print(secrets.token_hex(32))"`).
# Leave empty for local dev (a random key is generated each restart).
SESSION_SECRET=
SESSION_MAX_AGE_DAYS=30
